<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EJAA Professional Chat</title>
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
    <style>
        :root { --primary: #4facfe; --bg: #fdfbfb; }
        body { font-family: 'Poppins', sans-serif; background: #0f172a; margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; }
        
        /* Chat Panel */
        #chat-panel { width: 400px; height: 600px; background: white; border-radius: 20px; overflow: hidden; display: flex; flex-direction: column; position: relative; box-shadow: 0 20px 50px rgba(0,0,0,0.3); }
        
        /* Moving Background */
        .chat-body { flex: 1; background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%); position: relative; overflow-y: auto; padding: 20px; }
        
        /* Chat Bubbles */
        .bubble { padding: 12px 18px; border-radius: 20px; margin-bottom: 10px; max-width: 80%; font-family: 'Bangers', cursive; font-size: 1.2rem; }
        .bubble.out { align-self: flex-end; background: var(--primary); color: white; }
        .bubble.in { align-self: flex-start; background: white; color: #333; }
        
        /* Footer Controls */
        .controls { padding: 15px; display: flex; gap: 10px; background: white; }
        button { border: none; padding: 10px 15px; border-radius: 50px; cursor: pointer; background: #eee; }
        
        /* Video Overlay */
        #video-container { display: none; position: fixed; inset: 0; z-index: 1000; background: black; }
    </style>
</head>
<body>

<div id="chat-panel">
    <div class="chat-header" style="padding: 15px; background: #1e293b; color: white;">
        <span id="avatar">👤</span> EJAA Chat
        <button onclick="startVideoCall()" style="float: right;">📹 Call</button>
    </div>
    <div class="chat-body" id="chat-body">
        </div>
    <div class="controls">
        <input type="text" id="msgInput" style="flex:1;" placeholder="Type here...">
        <button onclick="sendMsg()">➤</button>
    </div>
</div>

<div id="video-container">
    <button onclick="closeCall()" style="position:absolute; top:20px; right:20px; z-index:1001;">✕</button>
    <iframe src="https://meet.jit.si/EJAA_Secure_Call" width="100%" height="100%" allow="camera; microphone; fullscreen"></iframe>
</div>

<script>
    // 1. Firebase Config (Keep your existing one)
    const firebaseConfig = { /* ... your config ... */ };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    // 2. Simple Video Call Trigger
    function startVideoCall() {
        document.getElementById('video-container').style.display = 'block';
    }

    function closeCall() {
        document.getElementById('video-container').style.display = 'none';
    }

    // 3. Send Message
    function sendMsg() {
        const text = document.getElementById('msgInput').value;
        db.ref('messages').push({ text: text, sender: 'User' });
        document.getElementById('msgInput').value = '';
    }

    // 4. Listen for Messages
    db.ref('messages').on('child_added', (snap) => {
        const msg = snap.val();
        const div = document.createElement('div');
        div.className = 'bubble in';
        div.textContent = msg.text;
        document.getElementById('chat-body').appendChild(div);
    });
</script>
</body>
</html>
